# =============================================================================
# Talkasauras Bot — Development Environment Configuration
# =============================================================================
# Copy this file to .env.development and fill in your values:
#
#   cp .env.development.example .env.development
#
# The app reads .env.development at startup via dotenv (src/config/env.ts:13).
# docker-compose.dev.yml also passes POSTGRES_USER/PASSWORD/DB from this file
# to the postgres container for initialization.
# =============================================================================

# ── NODE_ENV ─────────────────────────────────────────────────────────────────
# What:       Runtime environment mode. Tells the app to load .env.development
#             and enables dev-only behaviour (verbose logging, mock API).
# Used by:    src/config/env.ts:5, prisma.config.ts:4
# Get it:     Set this manually — always "development" for dev mode.
# Constraints: Must be exactly "development" (Zod enum validation).
# Example:    NODE_ENV=development
NODE_ENV=development

# ── PORT ─────────────────────────────────────────────────────────────────────
# What:       Port the Express HTTP server listens on. The host port is mapped
#             by docker-compose.dev.yml (container:5000 → host:5004).
# Used by:    src/config/env.ts:26 → checkEnv.ts:11 (validated 3000–5050)
# Get it:     Set any free port between 3000–5050. 5000 is standard.
# Constraints: Integer. Min 3000, max 5050.
# Example:    PORT=5000
PORT=5000

# ── DATABASE_URL ─────────────────────────────────────────────────────────────
# What:       Full PostgreSQL connection URL used by Prisma at runtime.
#             The dev Postgres container (docker-compose.dev.yml:31) runs on
#             port 5003 (mapped to internal 5432). The app connects via
#             localhost:5003 because it runs on the host, not in Docker.
# Used by:    src/config/env.ts:28 → checkEnv.ts:13, Prisma ORM
# Get it:     Derive from POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB below.
#             Format: postgresql://<user>:<password>@localhost:5003/<db>?schema=public
# Constraints: Valid URL. Must end with ?schema=public.
# Example:    DATABASE_URL=postgresql://postgres:password@localhost:5003/talkasauras_bot?schema=public
DATABASE_URL=postgresql://<user>:<password>@localhost:5003/<database>?schema=public

# ── POSTGRES_USER ────────────────────────────────────────────────────────────
# What:       PostgreSQL superuser role name. The postgres Docker container
#             uses this to create the initial database cluster on first start.
#             Must match the user in DATABASE_URL.
# Used by:    docker-compose.dev.yml:38 — passed as env_file to postgres service
# Get it:     Choose any name. "postgres" is the default for the official image.
# Constraints: Must be a valid PostgreSQL role name.
# Example:    POSTGRES_USER=postgres
POSTGRES_USER=<postgres_username>

# ── POSTGRES_PASSWORD ────────────────────────────────────────────────────────
# What:       Password for the PostgreSQL superuser. Used by the postgres Docker
#             container to secure the database. Must match the password in
#             DATABASE_URL.
# Used by:    docker-compose.dev.yml:38 — passed as env_file to postgres service
# Get it:     Choose a strong password. "password" is fine for local dev.
# Constraints: Must be a valid PostgreSQL password.
# Example:    POSTGRES_PASSWORD=password
POSTGRES_PASSWORD=<postgres_password>

# ── POSTGRES_DB ──────────────────────────────────────────────────────────────
# What:       Name of the default database created by the postgres container
#             on first start. Must match the database name in DATABASE_URL.
# Used by:    docker-compose.dev.yml:38 — passed as env_file to postgres service
# Get it:     Choose any name. "talkasauras_bot" is standard.
# Constraints: Must be a valid PostgreSQL database name.
# Example:    POSTGRES_DB=talkasauras_bot
POSTGRES_DB=<database_name>

# ── REDIS_USERNAME ───────────────────────────────────────────────────────────
# What:       Redis username for authentication. In local dev, the default
#             Redis user is "default" (no ACL configured).
# Used by:    src/config/env.ts:31 → checkEnv.ts:16 → src/modules/queue/redisConfig.ts
# Get it:     Use "default" unless you've configured Redis ACLs.
# Constraints: Non-empty string.
# Example:    REDIS_USERNAME=default
REDIS_USERNAME=<redis_username>

# ── REDIS_PASSWORD ───────────────────────────────────────────────────────────
# What:       Redis password for authentication. In local dev Docker, set this
#             to match whatever password you configure for the Redis container.
#             The dev compose file doesn't set a password by default, so
#             "password" is used for consistency.
# Used by:    src/config/env.ts:32 → checkEnv.ts:17 → src/modules/queue/redisConfig.ts
# Get it:     Choose any string for local dev. For production, use a strong one.
# Constraints: Non-empty string.
# Example:    REDIS_PASSWORD=password
REDIS_PASSWORD=<redis_password>

# ── REDIS_HOST ───────────────────────────────────────────────────────────────
# What:       Redis server hostname. In dev, the Redis container is mapped to
#             host port 5001, so the app connects to localhost.
# Used by:    src/config/env.ts:33 → checkEnv.ts:18 → src/modules/queue/redisConfig.ts
# Get it:     Use "localhost" when the app runs on the host machine and Redis
#             runs in Docker. Use "redis" when both are in the same Docker network.
# Constraints: Non-empty string (hostname or IP).
# Example:    REDIS_HOST=localhost
REDIS_HOST=<redis_host>

# ── REDIS_PORT ───────────────────────────────────────────────────────────────
# What:       Redis server port. In dev, the compose file maps host:5001 → container:6379.
#             The app connects to the host-mapped port (5001), not the internal one.
# Used by:    src/config/env.ts:34 → checkEnv.ts:19 → src/modules/queue/redisConfig.ts
# Get it:     Use 5001 for dev (host-mapped). Use 6379 inside Docker network.
# Constraints: Integer. Min 1, max 65535.
# Example:    REDIS_PORT=5001
REDIS_PORT=<redis_port>

# ── TELEGRAM_BOT_TOKEN ──────────────────────────────────────────────────────
# What:       Token for the main user-facing Telegram bot. This is the bot your
#             users will interact with (send messages, set reminders, chat, etc.)
# Used by:    src/config/env.ts:37 → checkEnv.ts:22 → src/config/bot.ts (Telegraf instance)
# Get it:     Create a bot via @BotFather (https://t.me/BotFather) on Telegram.
#             Use the /newbot command, choose a name and username, then copy the
#             token. Format: <digits>:<alphanumeric>.
# Constraints: Non-empty string. Must be a valid Telegram Bot API token.
# Example:    TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwxyz
TELEGRAM_BOT_TOKEN=<telegram_bot_token>

# ── TELEGRAM_BOT_TOKEN_INTERNAL ──────────────────────────────────────────────
# What:       Token for the admin/internal Telegram bot. This is a separate bot
#             used exclusively for administrative commands (broadcast, analytics,
#             feedback review). Isolates admin operations from regular users.
# Used by:    src/config/env.ts:54 → checkEnv.ts:35 → src/config/adminBot.ts (Telegraf instance)
# Get it:     Create a second bot via @BotFather (https://t.me/BotFather) —
#             same process as the main bot, but with a different name/username.
# Constraints: Non-empty string. Must be a valid Telegram Bot API token.
# Example:    TELEGRAM_BOT_TOKEN_INTERNAL=0987654321:ZYXwvutsRQPOmnlkJIhgfEDCBA
TELEGRAM_BOT_TOKEN_INTERNAL=<admin_bot_token>

# ── OLLAMA_API_KEY ───────────────────────────────────────────────────────────
# What:       API key for authenticating with the Ollama API endpoint. Required
#             even for local Ollama instances that don't enforce auth (the SDK
#             expects a non-empty value).
# Used by:    src/config/env.ts:40 → checkEnv.ts:25 → src/config/ollama.ts
# Get it:     • Local Ollama: any placeholder string (e.g., "ollama") works.
#             • Ollama.com cloud: sign up at https://ollama.com and generate an
#               API key from your account settings.
#             • Self-hosted: check your instance's admin panel.
# Constraints: Non-empty string.
# Example:    OLLAMA_API_KEY=dbdb8a9c2cc847369786f3daa54773ef.I7oJkOuST3ng7mdnFyWas153
OLLAMA_API_KEY=<ollama_api_key>

# ── OLLAMA_HOST ──────────────────────────────────────────────────────────────
# What:       Base URL of the Ollama API server. Can point to a local Docker
#             container (port 5005 with local-ollama profile) or a remote cloud
#             endpoint.
# Used by:    src/config/env.ts:41 → checkEnv.ts:26 → src/config/ollama.ts
# Get it:     • Local Docker (profile: local-ollama): http://localhost:5005
#             • Ollama.com cloud: https://ollama.com
#             • Self-hosted: http://<your-server>:11434
# Constraints: Valid URL format.
# Example:    OLLAMA_HOST=http://localhost:5005
OLLAMA_HOST=<ollama_host_url>

# ── OLLAMA_MODEL_NAME ────────────────────────────────────────────────────────
# What:       The specific LLM model to use for generating chat responses. The
#             model must be available (pulled) on the Ollama server specified
#             by OLLAMA_HOST.
# Used by:    src/config/env.ts:42 → checkEnv.ts:27 → src/config/ollama.ts
# Get it:     • List available models: ollama list (CLI) or GET /api/tags
#             • Pull a new model: ollama pull <model-name> (CLI)
#             • Common models: llama3.2, minimax-m2.1, gemma3, mistral, qwen2.5
#             • If using the mock API (dev only), any name works.
# Constraints: Non-empty string. Must be a model name recognized by your Ollama server.
# Example:    OLLAMA_MODEL_NAME=llama3.2
OLLAMA_MODEL_NAME=<ollama_model_name>

# ── SECRET_KEY_1 ─────────────────────────────────────────────────────────────
# What:       HMAC-SHA256 secret key. Used to hash Telegram user IDs before
#             storing them in the database (telegramIdHash field). This prevents
#             direct exposure of raw Telegram IDs in the database.
# Used by:    src/config/env.ts:46 → checkEnv.ts:31 → src/utils/crypto.ts (HMAC)
# Get it:     Generate a 32-byte (64 hex char) random string:
#               openssl rand -hex 32
# Constraints: Exactly 64 hexadecimal characters (32 bytes). Zod validates min 32 chars.
# Example:    SECRET_KEY_1=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b
SECRET_KEY_1=<64_hex_chars_hmac_key>

# ── SECRET_KEY_2 ─────────────────────────────────────────────────────────────
# What:       AES-256-GCM encryption key. Used to encrypt sensitive user data
#             at rest in the database — Telegram IDs (telegramIdEnc), user
#             messages, custom instructions, and reminders.
# Used by:    src/config/env.ts:47 → checkEnv.ts:32 → src/utils/crypto.ts (encrypt/decrypt)
# Get it:     Generate a 32-byte (64 hex char) random string:
#               openssl rand -hex 32
#             IMPORTANT: This key should be different from SECRET_KEY_1.
# Constraints: Exactly 64 hexadecimal characters (32 bytes). Zod validates min 32 chars.
# Example:    SECRET_KEY_2=b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c
SECRET_KEY_2=<64_hex_chars_aes_key>

# ── ADMINS ───────────────────────────────────────────────────────────────────
# What:       Pipe-separated (|) list of Telegram usernames or numeric user IDs
#             that are authorized to access the admin bot commands. Admin
#             capabilities include: broadcast messages, analytics, feedback
#             review, and system status checks.
# Used by:    src/config/env.ts:50-53 → parsed into array → src/modules/admin/services.ts
# Get it:     • Username: your public Telegram handle (e.g., "john_doe")
#             • User ID: get it from @userinfobot on Telegram (e.g., "123456789")
#             Add multiple admins separated by pipes: "user1|user2|123456789"
#             To find your own user ID, message @getidsbot on Telegram.
# Constraints: Non-empty pipe-separated strings. At least one admin required.
# Example:    ADMINS=john_doe|jane_smith|123456789
ADMINS=<username_or_userid>
