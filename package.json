{
    "name": "talkasauras_bot",
    "version": "1.0.0",
    "description": "A Telegram bot powered by Ollama LLM with real-time messaging, job queuing, and database persistence",
    "type": "module",
    "main": "./build/index.js",
    "keywords": [
        "telegram",
        "bot",
        "ollama",
        "llm",
        "ai",
        "messaging"
    ],
    "author": "IamDevTrivedi",
    "repository": {
        "type": "git",
        "url": "https://github.com/IamDevTrivedi/Talkasauras_Bot"
    },
    "scripts": {
        "build": "tsc && tsc-alias",
        "dev": "cross-env NODE_ENV=development tsx watch --clear-screen=true --tsconfig tsconfig.json --watch src src/index.ts",
        "start": "cross-env NODE_ENV=production node dist/index.js",
        "clean:all": "node scripts/clean-all.js",
        "install:all": "node scripts/install-all.js",
        "reset:all": "node scripts/reset-all.js",
        "check": "pnpm lint:check && pnpm format:check",
        "lint": "eslint . --fix",
        "lint:check": "eslint . --max-warnings=0",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio --browser none",
        "db:seed": "tsx prisma/seed.ts",
        "db:reset": "prisma migrate reset",
        "prepare": "husky"
    },
    "license": "MIT",
    "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
    "dependencies": {
        "@prisma/adapter-pg": "^7.4.0",
        "@prisma/client": "^7.4.0",
        "bullmq": "^5.69.2",
        "chrono-node": "^2.9.0",
        "cross-env": "^10.1.0",
        "dotenv": "^16.6.1",
        "express": "^5.2.1",
        "ollama": "^0.6.3",
        "pino": "^10.3.1",
        "pino-pretty": "^13.1.3",
        "redis": "^5.10.0",
        "telegraf": "^4.16.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "eslint": "^10.2.0",
        "husky": "^9.1.7",
        "prettier": "3.8.2",
        "prisma": "^7.7.0",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.58.1"
    }
}
