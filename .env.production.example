# =============================================================================
# Talkasauras Bot — Production Environment Configuration
# =============================================================================
# Copy this file to .env.production and fill in your values:
#
#   cp .env.production.example .env.production
#
# Docker Compose reads this file (docker-compose.yml:15 — env_file) and
# injects every variable into the bot container's process environment.
# The app reads them from process.env — it does NOT read .env.production
# via dotenv in production mode (src/config/env.ts:15 falls through to
# dotenv.config() with no path, but all vars are already on the process).
# =============================================================================

# ── NODE_ENV ─────────────────────────────────────────────────────────────────
# What:       Runtime environment mode. Disables dev-only behaviour, enables
#             production logging levels, and signals Prisma to use production
#             connection settings.
# Used by:    src/config/env.ts:5, prisma.config.ts:4, Dockerfile CMD
# Get it:     Set this manually — always "production" for production mode.
# Constraints: Must be exactly "production" (Zod enum validation).
# Example:    NODE_ENV=production
NODE_ENV=production

# ── PORT ─────────────────────────────────────────────────────────────────────
# What:       Port the Express HTTP server listens on inside the container.
#             docker-compose.yml maps host:5004 → container:5000.
# Used by:    src/config/env.ts:26 → checkEnv.ts:11 (validated 3000–5050)
# Get it:     Set to 5000 (internal container port). Host mapping is configured
#             in docker-compose.yml.
# Constraints: Integer. Min 3000, max 5050.
# Example:    PORT=5000
PORT=5000

# ── DATABASE_URL ─────────────────────────────────────────────────────────────
# What:       Full PostgreSQL connection URL used by Prisma at runtime.
#             In production (e.g., Supabase), this typically points to the
#             pgBouncer connection pooler port (6543) for efficient connection
#             management in transaction mode.
# Used by:    src/config/env.ts:28 → checkEnv.ts:13, Prisma ORM at runtime
# Get it:     • Supabase: Project Settings → Database → Connection string
#               (with pgBouncer, port 6543, ?pgbouncer=true)
#             • Self-hosted: postgresql://<user>:<password>@<host>:5432/<db>?schema=public
#             • Railway / Render: provided in your project dashboard
# Constraints: Valid URL format. Must end with ?schema=public typically.
# Example:    DATABASE_URL=postgresql://postgres:password@db.example.com:6543/talkasauras_bot?pgbouncer=true&schema=public
DATABASE_URL=<postgresql_connection_url>

# ── DIRECT_URL ───────────────────────────────────────────────────────────────
# What:       Direct PostgreSQL connection URL that bypasses pgBouncer (or any
#             connection pooler). Prisma CLI uses this for schema migrations
#             (DDL statements) because they require a direct connection.
#             NOT consumed by the running app — only by prisma migrate commands.
# Used by:    prisma.config.ts:18 — datasource URL for Prisma CLI
# Get it:     Same host/credentials as DATABASE_URL, but use the direct port
#             (typically 5432 instead of 6543) and omit the pgBouncer flag.
#             • Supabase: Project Settings → Database → Direct connection
# Constraints: Valid URL format.
# Example:    DIRECT_URL=postgresql://postgres:password@db.example.com:5432/talkasauras_bot?schema=public
DIRECT_URL=<direct_postgresql_connection_url>

# ── REDIS_USERNAME ───────────────────────────────────────────────────────────
# What:       Redis username for authentication. Default Redis user is "default"
#             unless ACL rules have been configured on the server.
# Used by:    src/config/env.ts:31 → checkEnv.ts:16 → src/modules/queue/redisConfig.ts
# Get it:     • Redis Cloud / Upstash: provided in connection details
#             • Self-hosted with ACL: the username you configured
#             • Default: "default"
# Constraints: Non-empty string.
# Example:    REDIS_USERNAME=default
REDIS_USERNAME=<redis_username>

# ── REDIS_PASSWORD ───────────────────────────────────────────────────────────
# What:       Redis password for authentication. The docker-compose.yml redis
#             service doesn't set a password by default, but production Redis
#             instances (Upstash, Redis Cloud, self-hosted) will require one.
# Used by:    src/config/env.ts:32 → checkEnv.ts:17 → src/modules/queue/redisConfig.ts
# Get it:     • Redis Cloud / Upstash: provided in connection details
#             • Self-hosted: the password from your redis.conf or AUTH command
# Constraints: Non-empty string. Use a strong, randomly generated password.
# Example:    REDIS_PASSWORD=aB3dEfGhIjKlMnOpQrStUvWxYz123456
REDIS_PASSWORD=<redis_password>

# ── REDIS_HOST ───────────────────────────────────────────────────────────────
# What:       Redis server hostname. In the production Docker Compose setup,
#             both the bot and redis containers share the same Docker network,
#             so the hostname is the service name "redis".
# Used by:    src/config/env.ts:33 → checkEnv.ts:18 → src/modules/queue/redisConfig.ts
# Get it:     • Docker Compose: "redis" (service name from docker-compose.yml)
#             • Redis Cloud / Upstash: provided endpoint hostname
#             • Self-hosted: your server's IP or hostname
# Constraints: Non-empty string (hostname or IP).
# Example:    REDIS_HOST=redis
REDIS_HOST=<redis_host>

# ── REDIS_PORT ───────────────────────────────────────────────────────────────
# What:       Redis server port. Inside the Docker network, Redis listens on
#             its default port 6379. No host-mapping is needed.
# Used by:    src/config/env.ts:34 → checkEnv.ts:19 → src/modules/queue/redisConfig.ts
# Get it:     • Docker network: 6379 (default Redis port)
#             • Redis Cloud / Upstash: provided in connection details
#             • Self-hosted: your configured Redis port
# Constraints: Integer. Min 1, max 65535.
# Example:    REDIS_PORT=6379
REDIS_PORT=<redis_port>

# ── TELEGRAM_BOT_TOKEN ──────────────────────────────────────────────────────
# What:       Token for the main user-facing Telegram bot. This is the bot your
#             users will interact with — sending messages, setting reminders,
#             providing feedback, etc.
# Used by:    src/config/env.ts:37 → checkEnv.ts:22 → src/config/bot.ts (Telegraf instance)
# Get it:     Create a bot via @BotFather (https://t.me/BotFather) on Telegram:
#             1. Start a chat with @BotFather
#             2. Send /newbot
#             3. Choose a display name (e.g., "Talkasauras")
#             4. Choose a username (e.g., "TalkasaurasBot")
#             5. Copy the token (format: <digits>:<alphanumeric>)
#             Keep this token secret — it grants full control of your bot.
# Constraints: Non-empty string. Must be a valid Telegram Bot API token.
# Example:    TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrstUVwxyz
TELEGRAM_BOT_TOKEN=<telegram_bot_token>

# ── TELEGRAM_BOT_TOKEN_INTERNAL ──────────────────────────────────────────────
# What:       Token for the admin/internal Telegram bot. This is a completely
#             separate bot used exclusively for administrative tasks (broadcast
#             messaging, analytics, feedback review, system status). Isolating
#             admin operations from the main bot prevents accidental exposure
#             of admin commands to regular users.
# Used by:    src/config/env.ts:54 → checkEnv.ts:35 → src/config/adminBot.ts (Telegraf instance)
# Get it:     Create a second bot via @BotFather (https://t.me/BotFather):
#             Same process as the main bot, but with a different name/username
#             (e.g., "TalkasaurasAdminBot"). Copy and store the token securely.
#             Only you and your team should know this bot exists.
# Constraints: Non-empty string. Must be a valid Telegram Bot API token.
# Example:    TELEGRAM_BOT_TOKEN_INTERNAL=0987654321:ZYXwvutsRQPOmnlkJIhgfEDCBA
TELEGRAM_BOT_TOKEN_INTERNAL=<admin_bot_token>

# ── OLLAMA_API_KEY ───────────────────────────────────────────────────────────
# What:       API key for authenticating with the Ollama API endpoint. Used by
#             the Ollama JS SDK to authorize all LLM requests.
# Used by:    src/config/env.ts:40 → checkEnv.ts:25 → src/config/ollama.ts
# Get it:     • Ollama.com cloud: sign up at https://ollama.com, go to your
#               account settings, and generate an API key.
#             • Self-hosted remote: check your instance's admin panel.
#             • Local only: you typically still need a non-empty placeholder.
# Constraints: Non-empty string.
# Example:    OLLAMA_API_KEY=dbdb8a9c2cc847369786f3daa54773ef.I7oJkOuST3ng7mdnFyWas153
OLLAMA_API_KEY=<ollama_api_key>

# ── OLLAMA_HOST ──────────────────────────────────────────────────────────────
# What:       Base URL of the Ollama API server. In production, this is
#             typically a cloud-hosted endpoint or a remote self-hosted server.
# Used by:    src/config/env.ts:41 → checkEnv.ts:26 → src/config/ollama.ts
# Get it:     • Ollama.com cloud: https://ollama.com
#             • Self-hosted: http://<your-server-ip>:11434
#             • RunPod / other GPU cloud: provided endpoint URL
# Constraints: Valid URL format (must include protocol).
# Example:    OLLAMA_HOST=https://ollama.com
OLLAMA_HOST=<ollama_host_url>

# ── OLLAMA_MODEL_NAME ────────────────────────────────────────────────────────
# What:       The specific LLM model to use for generating chat responses. The
#             model must be available (pulled) on the Ollama server specified
#             by OLLAMA_HOST.
# Used by:    src/config/env.ts:42 → checkEnv.ts:27 → src/config/ollama.ts
# Get it:     • List available models: curl <OLLAMA_HOST>/api/tags
#             • Common production models: llama3.2 (8B), minimax-m2.1, gemma3,
#               mistral (7B), qwen2.5 (7B/14B/32B/72B)
#             • Choose based on your performance/quality tradeoff.
# Constraints: Non-empty string. Must be a model name recognized by your server.
# Example:    OLLAMA_MODEL_NAME=llama3.2
OLLAMA_MODEL_NAME=<ollama_model_name>

# ── SECRET_KEY_1 ─────────────────────────────────────────────────────────────
# What:       HMAC-SHA256 secret key. Used to hash Telegram user IDs before
#             storing them in the database (the telegramIdHash field). This
#             prevents direct exposure of raw Telegram IDs if the database is
#             compromised, while still allowing consistent lookups.
# Used by:    src/config/env.ts:46 → checkEnv.ts:31 → src/utils/crypto.ts (HMAC)
# Get it:     Generate a cryptographically random 32-byte value as hex:
#               openssl rand -hex 32
#             Output example: f29a0b98b9672530a4c1a0e57a072cb17b9d6291e16b9aa7f42bfece8cb26d03
#             Store this securely — changing it will invalidate all existing
#             user ID hashes in the database.
# Constraints: At least 32 characters (Zod), but must be exactly 64 hex chars
#             (32 bytes) for proper AES-256 operation.
# Example:    SECRET_KEY_1=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b
SECRET_KEY_1=<64_hex_chars_hmac_key>

# ── SECRET_KEY_2 ─────────────────────────────────────────────────────────────
# What:       AES-256-GCM encryption key. Used to encrypt all sensitive user
#             data at rest: Telegram IDs (telegramIdEnc), message content,
#             custom instructions, and reminder text. Each encryption operation
#             uses a random 12-byte IV and includes authentication tags.
# Used by:    src/config/env.ts:47 → checkEnv.ts:32 → src/utils/crypto.ts (encrypt/decrypt)
# Get it:     Generate a cryptographically random 32-byte value as hex:
#               openssl rand -hex 32
#             Output example: 8a25a86659cefef391841dfd6ea3dc5a53ffd31d5e19f981dc421e7486d3c510
#             IMPORTANT: This key must be different from SECRET_KEY_1. Store
#             it securely — lost keys mean unrecoverable encrypted data.
# Constraints: At least 32 characters (Zod), but must be exactly 64 hex chars
#             (32 bytes) for proper AES-256 operation.
# Example:    SECRET_KEY_2=b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c
SECRET_KEY_2=<64_hex_chars_aes_key>

# ── ADMINS ───────────────────────────────────────────────────────────────────
# What:       Pipe-separated (|) list of Telegram usernames or numeric user IDs
#             authorized to access the admin bot. Admin capabilities include:
#             broadcasting messages to users, viewing analytics, reviewing
#             feedback, checking system status and queue depths.
# Used by:    src/config/env.ts:50-53 → parsed into string[] → src/modules/admin/services.ts
# Get it:     • Username: your public Telegram handle (e.g., "john_doe")
#             • User ID: message @userinfobot or @getidsbot on Telegram
#             To add multiple admins, separate with pipes:
#               "john_doe|jane_smith|123456789"
#             Only these users can interact with the admin bot.
# Constraints: Non-empty, pipe-separated strings. At least one admin required.
# Example:    ADMINS=john_doe|jane_smith|123456789
ADMINS=<username_or_userid>
